# Copy this file to .env and fill in your actual Cloudinary credentials. Never commit .env to version control.

# Port configuration for the dev server
PORT=5173

# Application Details
VITE_APP_TITLE=VoiceCheck
VITE_APP_VERSION=1.0.0

# API base endpoint
VITE_API_URL=http://localhost:8000/api

# Backend Server Port
BACKEND_PORT=8000

# MongoDB URI connection string
MONGODB_URI=mongodb://127.0.0.1:27017/voicecheck

# JWT Sign secret
JWT_SECRET=8156305f149533f17e2167e75753d6632e48fac8a67466d77cc08f60b66a4b22

# Cloudinary Integration
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name_here
VITE_CLOUDINARY_UPLOAD_PRESET=voicecheck_unsigned
VITE_CLOUDINARY_FOLDER=voicecheck/recordings
VITE_MAX_FILE_SIZE_MB=50

# Transcription Service Configuration
VITE_TRANSCRIPTION_API_URL=http://localhost:8001
