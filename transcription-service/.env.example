# Whisper model settings
WHISPER_MODEL_SIZE=small
# Options: tiny, base, small, medium, large-v3, large-v3-turbo
# "small" is a good CPU-friendly default with decent multilingual 
# accuracy. Use "medium" or "large-v3" if you have GPU access — 
# significantly better for Hindi/Tamil/Telugu/Kannada.

WHISPER_DEVICE=cpu
# Options: cpu, cuda

WHISPER_COMPUTE_TYPE=int8
# Options for cpu: int8, int8_float32 | for cuda: float16, int8_float16

# Embedding model for transcript similarity
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Alternative (multilingual, larger):
# sentence-transformers/LaBSE

# Similarity threshold for "Repeated Content" classification
REPEATED_CONTENT_THRESHOLD=0.92

# CORS — comma-separated list of allowed frontend origins.
# In production (Render), set this to your Vercel URL + localhost for local dev:
# CORS_ORIGINS=https://your-app.vercel.app,http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# Server port
PORT=8001

# Custom Hugging Face cache directory (useful if your C: drive is full)
# HF_HOME=W:\hf_cache
